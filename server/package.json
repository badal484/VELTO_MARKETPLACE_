{
  "name": "velto-server",
  "version": "1.0.0",
  "description": "Velto Backend API",
  "main": "src/server.ts",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register --files src/server.ts",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register --files src/server.ts",
    "seed": "ts-node -r tsconfig-paths/register --files src/seed.ts",
    "seed:mock": "ts-node -r tsconfig-paths/register --files src/seed.ts -- --mock"
  },
  "dependencies": {
    "@imagekit/nodejs": "^7.5.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.8.0",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^7.4.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.7.2",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.4.5",
    "@types/pdfkit": "^0.17.5",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
